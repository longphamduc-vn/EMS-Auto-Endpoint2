                        "value": "$.response.krPurchaser[*]"
                    }
                ]
            },
            {
                "name": "match_inventory_data",
                "label": "Match Aggregated Data",
                "type": "DATA_MAPPING",
                "description": "Combine data from RetStockStatusList and StockDetail based on Item code",
                "inputs": {
                    "sourceA": "$.StockStatusList",
                    "sourceB": "$.StockDetail"
                },
                "mapping": {
                    "joinType": "INNER_JOIN",
                    "joinKeys": [
                        {
                            "leftKey": "itemName",
                            "rightKey": "item"
                        }
                    ]
                },
                "extracts": [
                    {
                        "label": "Item Code",
                        "name": "itemCode",
                        "type": "JSON_PATH",
                        "value": "$.sourceA.itemName"
                    },
                    {
                        "label": "Item Name",
                        "name": "itemName",
                        "type": "JSON_PATH",
                        "value": "$.sourceA.itemDescription"
                    },
                    {
                        "label": "Maker Info",
                        "name": "makerInfo",
                        "type": "CALCULATION",
                        "value": "$.sourceA.maker + ' - ' + $.sourceA.model"
                    },
                    {
                        "label": "Inventory Status",
                        "name": "inventoryStatus",
                        "type": "CALCULATION",
                        "value": "$.sourceA.itemStatus == 'Active' && $.sourceB.availableQuantity > 0 ? 'In Stock' : 'Out of Stock'"
                    },
                    {
                        "label": "Total Onhand Qty",
                        "name": "totalOnhandQty",
                        "type": "JSON_PATH",
                        "value": "$.sourceB.onhandQuantity"
                    },
                    {
                        "label": "Available Qty",
                        "name": "availableQty",
                        "type": "JSON_PATH",
                        "value": "$.sourceB.availableQuantity"
                    },
                    {
                        "label": "Incoming Qty",
                        "name": "incomingQty",
                        "type": "CALCULATION",
                        "value": "Number($.sourceB.poWaitingQty) + Number($.sourceB.notReceivingQty)"
                    },
                    {
                        "label": "PO Block Status",
                        "name": "poBlockStatus",
                        "type": "CALCULATION",
                        "value": "$.sourceB.stopPo == 'Y' ? 'Blocked' : 'Allowed'"
                    },
                    {
                        "label": "Current Vendor",
                        "name": "currentVendor",
                        "type": "JSON_PATH",
                        "value": "$.sourceB.vendorName"
                    },
                    {
                        "label": "Need To Order",
                        "name": "needToOrder",
                        "type": "CALCULATION",
                        "value": "Number($.sourceB.availableQuantity) < Number($.sourceB.safetyStockQty) ? 'Yes' : 'No'"
                    }
                ]
            }
        ]
    }
]