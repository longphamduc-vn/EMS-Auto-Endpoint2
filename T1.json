                        "value": "$.response.domesticUnitPrice[*]"
                    }
                ]
            },
            {
                "name": "match_inventory_data",
                "label": "Match Aggregated Data",
                "type": "DATA_MAPPING",
                "description": "Combine data, format flags, remove duplicates for Estimate, and apply conditional styling.",
                "inputs": {
                    "sourceA": "$.StockStatusList",
                    "sourceB": "$.StockDetail",
                    "sourceC": "$.PoStatusCheck",
                    "sourceD": "$.EstimateHistory"
                },
                "mapping": {
                    "joinType": "LEFT_JOIN",
                    "joinKeys": [
                        {
                            "leftKey": "itemName",
                            "rightKey": "item",
                            "rightSource": "sourceB"
                        },
                        {
                            "leftKey": "itemName",
                            "rightKey": "item",
                            "rightSource": "sourceC"
                        },
                        {
                            "leftKey": "itemName",
                            "rightKey": "item",
                            "rightSource": "sourceD"
                        }
                    ]
                },
                "extracts": [
                    {
                        "label": "[QCode] Item Code",
                        "name": "itemCode",
                        "type": "JSON_PATH",
                        "value": "$.sourceA.itemName"
                    },
                    {
                        "label": "[QCode] Item Name",
                        "name": "itemName",
                        "type": "JSON_PATH",
                        "value": "$.sourceA.itemDescription"
                    },
                    {
                        "label": "[QCode] Maker Info",
                        "name": "makerInfo",
                        "type": "CALCULATION",
                        "value": "$.sourceA.maker + ' - ' + $.sourceA.model"
                    },
                    {
                        "label": "[QCode] UOM",
                        "name": "uomCode",
                        "type": "JSON_PATH",
                        "value": "$.sourceA.uomCode"
                    },
                    {
                        "label": "[Status] Inventory Status",
                        "name": "inventoryStatus",
                        "type": "CALCULATION",
                        "value": "$.sourceA.itemStatus == 'Active' && $.sourceB.availableQuantity > 0 ? 'In Stock' : 'Out of Stock'"
                    },
                    {
                        "label": "[Status] Disuse Flag",
                        "name": "disuseInventoryFlag",
                        "type": "CALCULATION",
                        "value": "$.sourceC.disuseInventoryFlag == 'Y' ? 'Y' : ''"
                    },
                    {
                        "label": "[Status] Aging Interlock Flag",
                        "name": "agingInterlockFlag",
                        "type": "CALCULATION",
                        "value": "$.sourceC.agingInterlockFlag == 'Y' ? 'Y' : ''"
                    },
                    {
                        "label": "[Status] Unit Price Flag",
                        "name": "unitPriceFlag",
                        "type": "CALCULATION",
                        "value": "$.sourceC.unitPriceFlag == 'Y' ? 'Y' : ''"
                    },
                    {
                        "label": "[Status] Wait Repair Flag",
                        "name": "waitRepairFlag",
                        "type": "CALCULATION",
                        "value": "$.sourceC.waitRepairFlag == 'Y' ? 'Y' : ''"
                    },
                    {
                        "label": "[Status] Apply Flag",
                        "name": "applyFlag",
                        "type": "CALCULATION",
                        "value": "$.sourceC.applyFlag == 'Y' ? 'Y' : ''"
                    },
                    {
                        "label": "[Price] Unit Price PO",
                        "name": "unitPricePo",
                        "type": "JSON_PATH",
                        "value": "$.sourceB.unitPricePo"
                    },
                    {
                        "label": "[Price] Estimate No",
                        "name": "estimateNo",
                        "type": "CALCULATION",
                        "value": "Array.isArray($.sourceD.estimateNo) ? [...new Set($.sourceD.estimateNo)].filter(Boolean).join(', ') : $.sourceD.estimateNo"
                    },
                    {
                        "label": "[Price] Estimate Cost",
                        "name": "estimateCost",
                        "type": "CALCULATION",
                        "value": "Array.isArray($.sourceD.estimateCost) ? [...new Set($.sourceD.estimateCost)].filter(Boolean).join(', ') : $.sourceD.estimateCost"
                    },
                    {
                        "label": "[Price] Domestic Unit Price",
                        "name": "domesticUnitPrice",
                        "type": "CALCULATION",
                        "value": "Array.isArray($.sourceD.domesticUnitPrice) ? [...new Set($.sourceD.domesticUnitPrice)].filter(Boolean).join(', ') : $.sourceD.domesticUnitPrice"
                    },
                    {
                        "label": "[Price] Date Accumulated",
                        "name": "dateAccumulated",
                        "type": "JSON_PATH",
                        "value": "$.sourceD.dateAccumulated"
                    },
                    {
                        "label": "[Inventory] Total Onhand Qty",
                        "name": "totalOnhandQty",
                        "type": "JSON_PATH",
                        "value": "$.sourceB.onhandQuantity"
                    },
                    {
                        "label": "[Inventory] Available Qty",
                        "name": "availableQty",
                        "type": "JSON_PATH",
                        "value": "$.sourceB.availableQuantity"
                    },
                    {
                        "label": "[Inventory] Incoming Qty",
                        "name": "incomingQty",
                        "type": "CALCULATION",
                        "value": "Number($.sourceB.poWaitingQty || 0) + Number($.sourceB.notReceivingQty || 0)"
                    },
                    {
                        "label": "[Inventory] Safety Stock",
                        "name": "safetyStockQty",
                        "type": "JSON_PATH",
                        "value": "$.sourceB.safetyStockQty"
                    },
                    {
                        "label": "[PO] Current Vendor",
                        "name": "vendorName",
                        "type": "JSON_PATH",
                        "value": "$.sourceB.vendorName"
                    },
                    {
                        "label": "[PO] PO Block Status",
                        "name": "poBlockStatus",
                        "type": "CALCULATION",
                        "value": "$.sourceB.stopPo == 'Y' ? 'Blocked' : 'Allowed'"
                    },
                    {
                        "label": "[PO] Stop PO Flag",
                        "name": "stopPoFlag",
                        "type": "CALCULATION",
                        "value": "$.sourceC.stopPoFlag == 'Y' ? 'Y' : ''"
                    },
                    {
                        "label": "[PO] PO Number",
                        "name": "poNo",
                        "type": "CALCULATION",
                        "value": "Array.isArray($.sourceD.poNo) ? [...new Set($.sourceD.poNo)].filter(Boolean).join(', ') : $.sourceD.poNo"
                    },
                    {
                        "label": "[PO] PO Amount",
                        "name": "poAmount",
                        "type": "CALCULATION",
                        "value
