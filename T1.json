                        "value": "$.response.agingInterlockFlag[*]"
                    },
                    {
                        "label": "Unit Price Flag",
                        "name": "unitPriceFlag",
                        "type": "JSON_PATH",
                        "value": "$.response.unitPriceFlag[*]"
                    },
                    {
                        "label": "Stop PO Flag",
                        "name": "stopPoFlag",
                        "type": "JSON_PATH",
                        "value": "$.response.stopPoFlag[*]"
                    },
                    {
                        "label": "Apply Flag",
                        "name": "applyFlag",
                        "type": "JSON_PATH",
                        "value": "$.response.applyFlag[*]"
                    },
                    {
                        "label": "Wait Repair Flag",
                        "name": "waitRepairFlag",
                        "type": "JSON_PATH",
                        "value": "$.response.waitRepairFlag[*]"
                    }
                ]
            },
            {
                "name": "EstimateHistory",
                "label": "Estimate History",
                "type": "HTTP_REQUEST",
                "loopOver": null,
                "cache": false,
                "accumulation": "$.accumulated_data.ItemStatus.EstimateHistory[?(@.item in $.StockDetail[*].item )]",
                "url": "http://ems.lgdisplay.com:9000/emsspareparts/sp101/sp120Nav/RetEstimateRequestList.lgdn",
                "method": "POST",
                "payload": {
                    "parameters": {
                        "_ems_userId": "658359",
                        "_ems_organizationId": "$.session.organizationId",
                        "_ems_language": "EN"
                    },
                    "datasets": [
                        {
                            "id": "ds_Search",
                            "fields": [
                                {
                                    "name": "organizationId",
                                    "value": "28753"
                                },
                                {
                                    "name": "itemType",
                                    "value": "Q"
                                },
                                {
                                    "name": "estimateRequestDateFrom",
                                    "value": "20250301"
                                },
                                {
                                    "name": "estimateRequestDateTo",
                                    "value": "20260327"
                                },
                                {
                                    "name": "userId",
                                    "value": "658359"
                                },
                                {
                                    "name": "itemYn",
                                    "value": "Y"
                                }
                            ]
                        },
                        {
                            "id": "ds_ItemInfo",
                            "fields": [
                                {
                                    "name": "item",
                                    "value": "$.input_items.items[*]"
                                }
                            ]
                        }
                    ]
                },
                "extracts": [
