                                {
                                    "name": "invItemList",
                                    "source": "$.StockStatusList.inventoryItemId"
                                }
                            ]
                        }
                    ]
                },
                "extracts": [
                    {
                        "label": "Item",
                        "name": "item",
                        "type": "JSON_PATH",
                        "value": "$.response.item[*]"
                    },
                    {
                        "label": "Disuse Inventory Flag",
                        "name": "disuseInventoryFlag",
