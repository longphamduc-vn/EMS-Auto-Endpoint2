                    },
                    {
                        "label": "Vendor Name",
                        "name": "vendorName",
                        "type": "JSON_PATH",
                        "value": "$.response.vendorName[*]"
                    },
                    {
                        "label": "Unit Price PO",
                        "name": "unitPricePo",
                        "type": "JSON_PATH",
                        "value": "$.response.unitPricePo[*]"
                    },
                    {
                        "label": "Stop PO",
                        "name": "stopPo",
                        "type": "JSON_PATH",
                        "value": "$.response.stopPo[*]"
                    },
                    {
                        "label": "Safety Stock Qty",
                        "name": "safetyStockQty",
                        "type": "JSON_PATH",
                        "value": "$.response.safetyStockQty[*]"
                    },
                    {
                        "label": "PO Waiting Qty",
                        "name": "poWaitingQty",
                        "type": "JSON_PATH",
                        "value": "$.response.poWaitingQty[*]"
                    },
                    {
                        "label": "Not Receiving Qty",
                        "name": "notReceivingQty",
                        "type": "JSON_PATH",
                        "value": "$.response.notReceivingQty[*]"
