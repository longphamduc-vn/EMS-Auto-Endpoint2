[
    {
        "name": "ItemStatus",
        "label": "Item Status",
        "description": "Item status and inventory tracking workflow",
        "parameters": {
            "session": {
                "organizationId": "28753",
                "itemCond": "Y",
                "optimizeFlag": "Y",
                "optimizedApplyDate": "20210316"
            }
        },
        "steps": [
            {
                "name": "input_items",
                "label": "Input Shipment Information",
                "type": "INPUT",
