                "url": "http://ems.lgdisplay.com:9000/emsspareparts/sp101/sp110Nav/RetStockStatusList.lgdn",
                "method": "POST",
                "payload": {
                    "parameters": {
                        "_ems_userId": "$.session.__ems_userId",
                        "_ems_organizationId": "$.session.__ems_organizationId"
                    },
                    "datasets": [
                        {
                            "id": "ds_search",
                            "fields": [
                                {
                                    "name": "organizationId",
                                    "value": "$.session.organizationId"
                                },
                                {
                                    "name": "itemCond",
                                    "value": "$.session.itemCond"
                                },
                                {
                                    "name": "optimizedApplyDate",
                                    "value": "$.session.optimizedApplyDate"
                                }
                            ]
                        },
                        {
                            "id": "ds_ItemInfo",
                            "fields": [
                                {
                                    "name": "item",
                                    "value": "$.input_items.items[*]"
                                }
                            ]
                        }
                    ]
                },
                "extracts": [
                    {
                        "label": "Date",
                        "name": "date",
                        "type": "CALCULATION",
                        "value": "1"
                    },
                    {
                        "label": "Item ID",
                        "name": "inventoryItemId",
                        "type": "JSON_PATH",
                        "value": "$.response.inventoryItemId[*]"
                    },
                    {
                        "label": "Q Code",
                        "name": "itemName",
                        "type": "JSON_PATH",
                        "value": "$.response.itemName[*]"
                    },
                    {
                        "label": "Item Description",
                        "name": "itemDescription",
                        "type": "JSON_PATH",
                        "value": "$.response.itemDescription[*]"
                    },
                    {
                        "label": "Item Status",
                        "name": "itemStatus",
                        "type": "JSON_PATH",
                        "value": "$.response.itemStatus[*]"
                    },
                    {
                        "label": "UOM Code",
                        "name": "uomCode",
                        "type": "JSON_PATH",
                        "value": "$.response.uomCode[*]"
                    },
                    {
                        "label": "Catalog Group",
                        "name": "catalogGroupName",
                        "type": "JSON_PATH",
                        "value": "$.response.catalogGroupName[*]"
                    },
                    {
                        "label": "Maker",
                        "name": "maker",
                        "type": "JSON_PATH",
                        "value": "$.response.maker[*]"
                    },
                    {
                        "label": "Model",
                        "name": "model",
                        "type": "JSON_PATH",
                        "value": "$.response.model[*]"
                    },
                    {
                        "label": "Item Spec",
                        "name": "itemSpec",
                        "type": "JSON_PATH",
                        "value": "$.response.itemSpec[*]"
                    },
                    {
                        "label": "Red Flag",
                        "name": "redFlag",
                        "type": "JSON_PATH",
                        "value": "$.response.redFlag[*]"
                    },
                    {
                        "label": "FDM URL",
                        "name": "fdmUrl",
                        "type": "JSON_PATH",
                        "value": "$.response.fdmUrl[*]"
                    }
                ],
                "styles": {
                    "rows": [
                        {
                            "when": {
                                "field": "itemStatus",
                                "operator": "eq",
                                "value": "Inactive"
                            },
                            "background": "#fff1f2"
                        }
                    ],
                    "columns": [
                        {
                            "field": "inventoryItemId",
                            "alignment": "right"
                        }
                    ]
                }
            },
            {
                "name": "StockDetail",
